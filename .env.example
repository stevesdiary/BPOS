# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
PLATFORM_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
SWAGGER_ENABLED=true

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Use the pooler endpoint for better connection management
DATABASE_URL=postgresql://user:password@host.pooler.neon.tech:6432/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=replace-with-at-least-32-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-32-char-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=bpos-files
R2_PUBLIC_URL=https://files.yourdomain.com

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Raw multipart upload cap enforced before sharp compression runs
MAX_UPLOAD_SIZE_BYTES=10485760

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx

# ─── Termii SMS ───────────────────────────────────────────────────────────────
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=BPOS

# ─── WhatsApp Business API (Phase 2) ─────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
